{
    "ARSEEK": {
        "summary": "Sets the ARINSERT / ARRING cursor to a specific index.",
        "complexity": "O(1)",
        "group": "array",
        "since": "8.8.0",
        "arity": 3,
        "function": "arseekCommand",
        "command_flags": [
            "WRITE",
            "FAST"
        ],
        "acl_categories": [
            "ARRAY"
        ],
        "key_specs": [
            {
                "flags": [
                    "RW",
                    "UPDATE"
                ],
                "begin_search": {
                    "index": {
                        "pos": 1
                    }
                },
                "find_keys": {
                    "range": {
                        "lastkey": 0,
                        "step": 1,
                        "limit": 0
                    }
                }
            }
        ],
        "reply_schema": {
            "description": "1 if the cursor was set, 0 if the key does not exist.",
            "type": "integer"
        },
        "arguments": [
            {
                "name": "key",
                "type": "key",
                "key_spec_index": 0
            },
            {
                "name": "index",
                "type": "integer"
            }
        ]
    }
}
